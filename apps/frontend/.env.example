# ══════════════════════════════════════════════════════════
# REX Frontend - Environment Configuration
# Copy this file to .env.local and update with your values
# ══════════════════════════════════════════════════════════

# ── API CONFIGURATION ──
# Backend API base URL (used for all API calls)
# Default: http://localhost:4000 (local development)
# Staging: https://staging-api.rex.internal
# Production: https://api.rex.internal
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── DEPLOYMENT ENVIRONMENT ──
# Environment identifier for analytics and error reporting
# Values: development, staging, production
NEXT_PUBLIC_ENVIRONMENT=development

# ── FEATURE FLAGS ──
# Enable/disable experimental features
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_KNOWLEDGE_BASE=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# ── THIRD-PARTY SERVICES ──
# Sentry error tracking (optional, recommended for production)
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ── VERSION INFO ──
# Application version (filled in during build)
# NEXT_PUBLIC_APP_VERSION=1.0.0

# ── LOGGING ──
# Enable verbose console logging in development
NEXT_PUBLIC_DEBUG_LOGGING=false

# ──────────────────────────────────────────────────────────
# NOTES:
# - All NEXT_PUBLIC_* variables are exposed to the browser
# - Never put sensitive data in NEXT_PUBLIC_* variables
# - Secrets should use non-NEXT_PUBLIC_ prefixed variables
# - After updating this file, restart Next.js dev server
# ──────────────────────────────────────────────────────────
