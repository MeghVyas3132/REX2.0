{
  "name": "@rex/frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:unit": "vitest run src/components/**/__tests__/*.test.ts src/components/**/__tests__/*.test.tsx src/lib/**/__tests__/*.test.ts src/features/__tests__/*.contract.test.ts",
    "test:integration": "vitest run src/tests/integration",
    "test:watch": "vitest",
    "test:e2e": "playwright test -c playwright.config.ts",
    "test:contracts": "vitest run src/features/__tests__/*.contract.test.ts",
    "test:api-client": "vitest run src/lib/api/__tests__/client.test.ts",
    "perf:bundle:report": "node ../../scripts/check-frontend-bundle-budget.mjs --report-only",
    "perf:bundle:check": "node ../../scripts/check-frontend-bundle-budget.mjs --maxTotalKB=18000 --maxChunkKB=7000",
    "clean": "rm -rf .next"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@rex/types": "workspace:^",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-table": "^8.20.5",
    "@xyflow/react": "^12.10.1",
    "framer-motion": "^12.38.0",
    "next": "15.1.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.53.2",
    "recharts": "^2.15.0",
    "sonner": "^1.7.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.1.6",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
